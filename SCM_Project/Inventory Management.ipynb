  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Define Business Parameters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Total Demand (yearly)\n",
    "D = 2000\n",
    "# Total Simulation Time (days)\n",
    "T_total = 365\n",
    "# Demand per Day\n",
    "D_day = D / T_total\n",
    "# Replenishment Period (days)\n",
    "T = 10\n",
    "# Purchase cost of the product (Euros/unit)\n",
    "c = 50\n",
    "# Cost of placing an order (/order)\n",
    "c_t = 500\n",
    "# Holding Cost (% unit cost per year)\n",
    "h = 0.25\n",
    "c_e = h * c\n",
    "# Selling Price (Euros/unit)\n",
    "p = 75\n",
    "# Cost of shortage (Euros/unit)\n",
    "c_s = 12\n",
    "\n",
    "print(f\"Daily Demand: {D_day:.2f} units/day\")\n",
    "print(f\"Order Quantity: {D_day * T:.2f} units per order\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Run Inventory Simulation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulation Parameters\n",
    "D1 = 2000           # Annual Demand\n",
    "LD1 = 0             # Lead Time (days)\n",
    "Q1 = D_day * T      # Order Quantity\n",
    "initial_ioh1 = Q1   # Initial Inventory on Hand\n",
    "\n",
    "# Create Parameters Object\n",
    "params1 = InventoryParams(\n",
    "    D=D1,\n",
    "    T_total=T_total,\n",
    "    LD=LD1,\n",
    "    T=T,\n",
    "    Q=Q1,\n",
    "    initial_ioh=initial_ioh1,  # Note: parameter name is 'initial_ioh'\n",
    "    sigma=0\n",
    ")\n",
    "\n",
    "print(\"Parameters created:\")\n",
    "print(f\"  Annual Demand: {params1.D}\")\n",
    "print(f\"  Daily Demand: {params1.D / params1.T_total:.2f}\")\n",
    "print(f\"  Review Period: {params1.T} days\")\n",
    "print(f\"  Order Quantity: {params1.Q:.2f} units\")\n",
    "print(f\"  Initial Inventory: {params1.initial_ioh:.2f} units\")\n",
    "\n",
    "# Run Simulation\n",
    "simulate_1 = InventorySimulation(params1)\n",
    "sim1 = simulate_1.simulation_1()\n",
    "\n",
    "print(\"\\n✅ Simulation completed!\")\n",
    "print(f\"Simulation results shape: {sim1.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
